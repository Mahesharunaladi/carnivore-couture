
{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": false,  // Change to false to relax rules
    "allowJs": true,  // Allow JS files
    "checkJs": false  // Disable JS checking
  },
  "include": ["vite.config.js"]
}